# --- 模型权重与训练输出 ---
# 绝对不要把模型权重传上去，太大了！
checkpoints/
*.pth
*.bin
*.pt
*.safetensors

# --- 数据集相关 ---
# 忽略整个 dataset 目录（除了 README 和必要的属性文件）
dataset/
# 如果你想保留 dataset 里的说明文档，可以加下面这两行：
!dataset/README.md
!dataset/.gitattributes

# 显式忽略所有 jsonl 数据文件，以防万一
*.jsonl

# --- Python 缓存与临时文件 ---
__pycache__/
*.py[cod]
*$py.class
.env
.venv
env/
venv/
.pytest_cache/

# --- 系统与编辑器临时文件 ---
.DS_Store
.vscode/
.idea/
*.swp
*.tmp